{
  "name": "@panyam/massrelay",
  "version": "0.0.10",
  "type": "module",
  "main": "dist/gen/massrelay/v1/models/collab_pb.js",
  "types": "dist/gen/massrelay/v1/models/collab_pb.d.ts",
  "exports": {
    "./models": {
      "types": "./dist/gen/massrelay/v1/models/collab_pb.d.ts",
      "default": "./dist/gen/massrelay/v1/models/collab_pb.js"
    },
    "./services": {
      "types": "./dist/gen/massrelay/v1/services/collab_pb.d.ts",
      "default": "./dist/gen/massrelay/v1/services/collab_pb.js"
    },
    "./client": {
      "types": "./dist/CollabClient.d.ts",
      "default": "./dist/CollabClient.js"
    },
    "./sync": {
      "types": "./dist/SyncAdapter.d.ts",
      "default": "./dist/SyncAdapter.js"
    },
    "./url": {
      "types": "./dist/url-params.d.ts",
      "default": "./dist/url-params.js"
    },
    "./crypto": {
      "types": "./dist/crypto.d.ts",
      "default": "./dist/crypto.js"
    },
    "./peers": {
      "types": "./dist/peerColors.d.ts",
      "default": "./dist/peerColors.js"
    },
    "./engine": {
      "types": "./dist/CollabEngine.d.ts",
      "default": "./dist/CollabEngine.js"
    },
    "./emitter": {
      "types": "./dist/EventEmitter.d.ts",
      "default": "./dist/EventEmitter.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "files": [
    "dist"
  ],
  "peerDependencies": {
    "@bufbuild/protobuf": "^2.0.0",
    "@panyam/servicekit-client": "^0.0.6"
  },
  "devDependencies": {
    "@bufbuild/protobuf": "^2.11.0",
    "@panyam/servicekit-client": "^0.0.6",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
