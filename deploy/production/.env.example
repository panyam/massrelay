# Domain for TLS (Caddy auto-provisions Let's Encrypt cert)
# Use "localhost" for local testing (Caddy serves self-signed)
RELAY_DOMAIN=r01.example.com

# OTEL service name — use a unique name per relay for pool identification
OTEL_SERVICE_NAME=massrelay-r01

# OTLP collector endpoint (leave empty to disable remote export)
# Example: https://otlp-gateway-prod-us-east-0.grafana.net/otlp
OTEL_EXPORTER_OTLP_ENDPOINT=

# Log first N chars of message payloads for debugging (0 = disabled)
RELAY_LOG_PAYLOADS=0

# Admin API bearer token (required to enable /admin/* endpoints)
# Generate one with: openssl rand -hex 32
RELAY_ADMIN_TOKEN=

# Security (optional, recommended for production)
# Comma-separated origin allowlist for WebSocket + CORS (empty = allow all)
RELAY_ALLOWED_ORIGINS=
# Comma-separated trusted proxy CIDRs for X-Forwarded-For (empty = trust all)
RELAY_TRUSTED_PROXIES=
# Max concurrent WebSocket connections (0 = unlimited)
RELAY_MAX_CONNECTIONS=500
# Rate limits (connections/sec)
RELAY_GLOBAL_RATE=100
RELAY_PER_IP_RATE=5
